function t(el) {
  if (typeof el === 'string') el = document.querySelector(el);
  if (!el) return;
  const d = el.getAttribute('data-' + currentLang);
  if (d !== null && d !== undefined) el.innerHTML = d;
}

function translateAll() {
  document.querySelectorAll('[data-es][data-en]').forEach(el => {
    const d = el.getAttribute('data-' + currentLang);
    if (d !== null) el.innerHTML = d;
  });
  // address form placeholder translations
  document.querySelectorAll('[data-es-placeholder][data-en-placeholder]').forEach(el => {
    el.placeholder = el.getAttribute('data-' + currentLang + '-placeholder');
  });
  // address form select options
  const addrCountry = document.getElementById('addrCountry');
  if (addrCountry) {
    const opt0 = addrCountry.querySelector('option[value=""]');
    if (opt0) opt0.textContent = currentLang === 'es' ? '— País *' : '— Country *';
