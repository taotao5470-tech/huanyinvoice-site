function renderProducts(filter) {
  const grid = document.getElementById('productsGrid');
  let filtered;
  if (filter === 'airpods-pro') {
    filtered = products.filter(p => p.cat === 'airpods-pro');
  } else if (filter === 'airpods') {
    filtered = products.filter(p => p.cat === 'airpods');
  } else if (filter === 'airpods-max') {
    filtered = products.filter(p => p.cat === 'airpods-max');
  } else {
    filtered = products.filter(p => p.cat === filter);
  }

  grid.innerHTML = filtered.map(p => {
    const bestVariant = p.variants.find(v => v.stock > 0) || p.variants[0];
    const price = bestVariant.prices.small || bestVariant.prices.large || 0;
    const allOOS = p.variants.every(v => v.stock === 0);
    const stockClass = allOOS ? 'oos' : bestVariant.stock < 500 ? 'low-stock' : 'in-stock';
    const stockText = allOOS ? { es: 'Agotado', en: 'Out of Stock' }
      : bestVariant.stock < 500 ? { es: 'Stock Limitado', en: 'Low Stock' }
      : { es: 'En Stock', en: 'In Stock' };
    const variantDots = p.variants.map(v => {
      const cls = v.stock === 0 ? 'v-dot-std' : v.id.includes('anc') ? 'v-dot-anc' : 'v-dot-global';
      return `<span class="variant-dot ${cls}" title="${v.name}"></span>`;
    }).join('');

    return `<div class="product-card${allOOS ? ' disabled' : ''}" onclick="${allOOS ? '' : `navigateToProduct('${p.id}')`}">
      <div class="product-img">
        <img class="pi-placeholder" src="${PLACEHOLDER_SVG}" alt="${p.name[currentLang]}">
        <div class="product-badge">
          ${p.id === 'airpods-pro-2' ? '<span class="badge badge-best">BESTSELLER</span>' : ''}
          ${p.id === 'airpods-pro-3' ? '<span class="badge badge-new">PREMIUM</span>' : ''}
          ${allOOS ? '<span class="badge badge-oos">0 STOCK</span>' : ''}
        </div>
        <div class="stock-dot ${stockClass}">${stockText[currentLang]}</div>
      </div>
      <div class="product-info">
        <div class="product-name">${p.name[currentLang]}</div>
        <div class="product-spec">${p.tagline[currentLang]}</div>
        <div class="variant-dots">${variantDots}</div>
        <div class="product-bottom">
          <div>
            <div class="product-price">${formatPrice(price)} <span>/ unit</span></div>
            <div class="product-moq" data-es="MOQ: 40 PCS" data-en="MOQ: 40 PCS">MOQ: 40 PCS</div>
          </div>
          <button class="btn btn-sm btn-dark" onclick="event.stopPropagation(); ${allOOS ? '' : `navigateToProduct('${p.id}')`}" ${allOOS ? 'disabled style="opacity:0.3"' : ''} data-es="Ver Detalle" data-en="View Detail">Ver Detalle</button>
        </div>
      </div>
    </div>`;
  }).join('');

  // re-translate
  document.querySelectorAll('#productsGrid [data-es][data-en]').forEach(el => {
    el.innerHTML = el.getAttribute('data-' + currentLang);
  });
}

