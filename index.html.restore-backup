          <input id="pdQtyInput" type="number" value="40" min="1" step="1" style="width:60px;height:30px;text-align:center;background:var(--bg-primary);color:var(--text-light);border:none;border-left:1px solid var(--border-dark);border-right:1px solid var(--border-dark);font-size:14px;font-weight:600;font-family:inherit;-moz-appearance:textfield" onchange="pdQtyValidate()" oninput="pdQtyValidate()">
          <button onclick="pdQtyUp()" style="width:30px;height:30px;background:var(--bg-primary);color:var(--text-light);font-size:16px;display:flex;align-items:center;justify-content:center;border:none;cursor:pointer">+</button>
        </div>
        <span style="font-size:10px;color:var(--text-muted)" data-es="Recomendado: 40+ unidades" data-en="Recommended: 40+ units">Recomendado: 40+ unidades</span>
      </div>

      <div class="pd-actions">
        <button class="btn btn-moss" onclick="addToCartWithQty('${p.id}', '${v.id}');" ${isOOS ? 'disabled style="opacity:0.4;pointer-events:none"' : ''} data-es="Agregar a Cotización" data-en="Add to Inquiry">Agregar a Cotización</button>
        <button class="btn btn-gray-green" onclick="toggleCart()" data-es="Calcular Envío" data-en="Calculate Shipping">Calcular Envío</button>
      </div>
    </div>
  `;

  // re-translate product detail
  document.querySelectorAll('#productDetail [data-es][data-en]').forEach(el => {
    el.innerHTML = el.getAttribute('data-' + currentLang);
  });
  // re-translate back button
  document.querySelectorAll('#pageProduct .btn-back [data-es][data-en]').forEach(el => {
    el.innerHTML = el.getAttribute('data-' + currentLang);
  });
  // init price display
  setTimeout(updatePriceDisplay, 50);
}

function switchVariant(productId, variantId) {
  const p = products.find(p => p.id === productId);
  const v = p.variants.find(v => v.id === variantId);
  if (v) { renderProductPage(productId, variantId); }
}

function selectPack(el) {
  el.parentElement.querySelectorAll('.pack-option').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  const pack = el.dataset.pack;
  const preview = document.getElementById('packPreview');
  if (!preview) return;
  const icons = { normal: '📦', standard: '📋', oem: '🏭' };
  const labels = currentLang === 'es'
    ? { normal: 'Empaque Normal — Bolsa básica', standard: 'Empaque Estándar — Caja genérica', oem: 'OEM Personalizado — Caja con tu marca' }
    : { normal: 'Normal Packaging — Basic bag', standard: 'Standard Packaging — Generic box', oem: 'OEM Custom — Branded box' };
  preview.innerHTML = `<div style="text-align:center">
    <div class="pack-preview-icon">${icons[pack] || '📦'}</div>
    <div class="pack-preview-label">${labels[pack] || ''}</div>
  </div>`;
}

// ============ Price Display Updater ============
function updatePriceDisplay() {
  const qty = getPdQty();
  const tierSmall = document.getElementById('tierSmall');
  const tierLarge = document.getElementById('tierLarge');
  const totalEl = document.getElementById('pdTotalPrice');
  if (!totalEl) return;

  const p = products.find(p => p.id === currentProductId);
  const v = p?.variants.find(v => v.id === currentVariantId);
  if (!v) return;
  const priceSmall = v.prices.small;
  const priceLarge = v.prices.large;

  const useLarge = priceLarge && qty >= 120;
  const unitPrice = useLarge ? priceLarge : priceSmall;

  if (tierSmall) tierSmall.classList.toggle('selected', !useLarge && !!priceSmall);
  if (tierLarge) tierLarge.classList.toggle('selected', useLarge);

  if (unitPrice) {
    totalEl.textContent = formatPrice(unitPrice * qty);
  }
}

// ============ SUB-CAT CLICK HANDLERS ============
document.getElementById('subCats').addEventListener('click', (e) => {
  if (e.target.classList.contains('sub-cat-btn')) {
    filterBySub(e.target.dataset.cat);
  }
});

// ============ KEYBOARD ============
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') {
    if (document.getElementById('cartPanel').classList.contains('open')) toggleCart();
    if (currentPage === 'product') navigateBack();
  }
});

// ============ BROWSER BACK/FORWARD ============
window.addEventListener('popstate', (e) => {
  if (e.state && e.state.page === 'product') {
    navigateToProduct(e.state.productId);
  } else if (e.state && e.state.page === 'secondary') {
    showPage('secondary');
    window.scrollTo(0, 0);
  } else {
    navigateBack();
  }
});

// Override navigateToProduct to push state
const origNavigateToProduct = navigateToProduct;
navigateToProduct = function(productId) {
  history.pushState({ page: 'product', productId }, '', '#product/' + productId);
  origNavigateToProduct(productId);
};

const origNavigateBack = navigateBack;
navigateBack = function() {
  const goingToHome = currentPage === 'secondary' || currentPage === 'product';
  history.pushState({ page: 'home' }, '', window.location.pathname);
  origNavigateBack();
};

// ============ INIT ============
function init() {
  setLang(currentLang);
  renderProducts('airpods-pro');
  updateCartUI();
  // handle initial hash
  const hash = window.location.hash;
  if (hash.startsWith('#product/')) {
    const pid = hash.replace('#product/', '');
    navigateToProduct(pid);
  } else if (hash === '#company') {
    showPage('secondary');
  }
}

init();
</script>
</body>
</html>
