.hero-float-card { position: absolute; z-index: 4; min-width: 132px; padding: 14px 16px; border-radius: 20px; background: rgba(10, 20, 30, 0.7); border: 1px solid rgba(255,255,255,0.13); box-shadow: 0 22px 55px rgba(0,0,0,0.24); backdrop-filter: blur(18px); animation: heroFloat 6s ease-in-out infinite; }
.hero-float-card span { display: block; font-size: 11px; letter-spacing: 1.8px; color: var(--accent-moss); font-weight: 800; }
.hero-float-card strong { display: block; font-size: 28px; line-height: 1.05; color: #fff; margin-top: 4px; }
.hero-float-card small { display: block; color: #9fb4bd; font-size: 11px; }
.float-qc { left: 2%; top: 15%; }
.float-oem { right: 0; top: 26%; animation-delay: -1.8s; }
.float-ddp { left: 10%; bottom: 13%; animation-delay: -3.2s; }
.hero-orb { position: absolute; z-index: 1; border-radius: 999px; filter: blur(2px); opacity: 0.55; pointer-events: none; }
