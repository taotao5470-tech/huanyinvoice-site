let cart = JSON.parse(localStorage.getItem('huanyin_cart') || '[]');

function saveCart() { localStorage.setItem('huanyin_cart', JSON.stringify(cart)); updateCartUI(); }

function addToCart(productId, variantId) {
  const existing = cart.find(c => c.productId === productId && c.variantId === variantId);
  if (existing) { existing.qty++; }
  else { cart.push({ productId, variantId, qty: 1, packaging: 'standard' }); }
  saveCart();
}

// Quantity handlers for product detail page
function getPdQty() {
  const input = document.getElementById('pdQtyInput');
  if (!input) return 1;
  let v = parseInt(input.value) || 40;
  if (v < 1) v = 1;
  input.value = v;
  return v;
}
function pdQtyDown() {
  const input = document.getElementById('pdQtyInput');
  if (!input) return;
  let v = (parseInt(input.value) || 1) - 1;
  if (v < 1) v = 1;
  input.value = v;
  updatePriceDisplay();
}
function pdQtyUp() {
  const input = document.getElementById('pdQtyInput');
  if (!input) return;
  let v = (parseInt(input.value) || 1) + 1;
  input.value = v;
  updatePriceDisplay();
}
function pdQtyValidate() {
  const input = document.getElementById('pdQtyInput');
  if (!input) return;
  let v = parseInt(input.value);
  if (isNaN(v) || v < 1) v = 1;
  input.value = v;
  updatePriceDisplay();
}
function addToCartWithQty(productId, variantId) {
  const qty = getPdQty();
  const existing = cart.find(c => c.productId === productId && c.variantId === variantId);
  if (existing) { existing.qty += qty; }
  else { cart.push({ productId, variantId, qty, packaging: 'standard' }); }
  saveCart();
  // brief feedback then navigate back
  const btn = document.querySelector('.pd-actions .btn-moss');
  if (btn) {
    const orig = btn.innerHTML;
    btn.innerHTML = currentLang === 'es' ? '✓ Agregado!' : '✓ Added!';
    btn.style.background = 'var(--success)';
    setTimeout(() => { navigateBack(); }, 400);
  } else {
    navigateBack();
  }
}

function removeFromCart(index) { cart.splice(index, 1); saveCart(); }

function updateQty(index, delta) {
  cart[index].qty += delta;
  if (cart[index].qty < 1) cart[index].qty = 1;
  saveCart();
}

function updateCartUI() {
  const count = cart.reduce((s, c) => s + c.qty, 0);
  const countEl = document.getElementById('cartCount');
  countEl.textContent = count;
  countEl.style.display = count > 0 ? 'flex' : 'none';
  renderCartItems();
}

function renderCartItems() {
  const container = document.getElementById('cartItems');
  const footer = document.getElementById('cartFooter');
  if (cart.length === 0) {
    container.innerHTML = `<div class="cart-empty">${currentLang === 'es' ? 'Tu cotización está vacía. Agrega productos desde nuestro catálogo.' : 'Your inquiry is empty. Add products from our catalog.'}</div>`;
    footer.style.display = 'none';
  } else {
    let total = 0;
    container.innerHTML = cart.map((c, i) => {
      const p = products.find(p => p.id === c.productId);
      if (!p) return '';
      const v = p.variants.find(v => v.id === c.variantId);
      if (!v) return '';
      const price = v.prices.small || v.prices.large || 0;
      total += price * c.qty;
      return `<div class="cart-item">
        <div class="cart-item-img">${p.icon}</div>
        <div class="cart-item-info">
          <div class="cart-item-name">${p.name[currentLang]}</div>
          <div class="cart-item-variant">${v.name}</div>
          <div class="cart-item-price">${formatPrice(price)}</div>
          <div class="cart-item-qty">
            <button onclick="updateQty(${i}, -1)">−</button>
            <span>${c.qty}</span>
            <button onclick="updateQty(${i}, 1)">+</button>
          </div>
        </div>
        <button class="cart-item-remove" onclick="removeFromCart(${i})">&#x2715;</button>
      </div>`;
    }).join('');
    document.getElementById('cartTotal').textContent = formatPrice(total);
    footer.style.display = 'block';
  }
}

function sendCartToWhatsApp() {
  syncAddress();
  if (!isAddressComplete()) {
    document.getElementById('addrWarn').style.display = 'block';
    return;
  }
  let msg = currentLang === 'es'
    ? '¡Hola! Solicito una cotización:\n\n📦 Productos:\n'
    : 'Hello, I would like to request a quotation:\n\n📦 Products:\n';
  cart.forEach(c => {
    const p = products.find(p => p.id === c.productId);
    const v = p?.variants.find(v => v.id === c.variantId);
    const price = v?.prices.small || v?.prices.large || 0;
    msg += `• ${p?.name[currentLang] || ''} — ${v?.name || ''} × ${c.qty} — ${formatPrice(price * c.qty)}\n`;
  });
  msg += '\n' + (currentLang === 'es' ? '🚚 Datos de envío:' : '🚚 Shipping info:') + '\n';
  msg += (currentLang === 'es' ? `País: ${cartAddress.country}\nEstado: ${cartAddress.state}\nCiudad: ${cartAddress.city}\nC.P.: ${cartAddress.zip}\n` : `Country: ${cartAddress.country}\nState: ${cartAddress.state}\nCity: ${cartAddress.city}\nZip: ${cartAddress.zip}\n`);
  if (cartAddress.fullAddress) msg += (currentLang === 'es' ? `Dirección: ${cartAddress.fullAddress}\n` : `Address: ${cartAddress.fullAddress}\n`);
  if (cartAddress.contactName) msg += (currentLang === 'es' ? `Contacto: ${cartAddress.contactName}\n` : `Contact: ${cartAddress.contactName}\n`);
  msg += '\n' + (currentLang === 'es' ? 'Por favor enviar:\n✅ Cotización de precios (MXN)\n✅ Costo de envío (DDP)\n✅ Tiempo de entrega' : 'Please provide:\n✅ Price quotation (USD)\n✅ Shipping cost (DDP)\n✅ Delivery time');
  window.open('https://wa.me/528261253244?text=' + encodeURIComponent(msg), '_blank');
}

