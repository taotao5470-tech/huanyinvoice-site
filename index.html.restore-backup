<!DOCTYPE html>
<html lang="es" dir="ltr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>HUANYIN — Premium Consumer Electronics</title>
<style>
/* ============ CSS Variables ============ */
:root {
  --bg-primary: #1c1c1c;
  --bg-secondary: #232323;
  --bg-surface: #faf7f2;
  --bg-card: #ffffff;
  --bg-dark-card: #2a2a2a;
  --accent-moss: #2d7dd2;
  --accent-moss-dark: #1a5fa8;
  --accent-moss-light: #e8f2fc;
  --accent-copper: #e8a835;
  --accent-copper-light: #fdf6e3;
  --text-dark: #1c1c1c;
  --text-light: #e8e4dd;
  --text-muted: #8a8a8a;
  --text-muted-dark: #6a6a6a;
  --whatsapp: #25D366;
  --whatsapp-dark: #1da851;
  --danger: #d94a4a;
  --warning: #d4a853;
  --success: #5a9e6f;
  --border: #e8e4dd;
  --border-dark: #3a3a3a;
  --shadow: 0 2px 16px rgba(0,0,0,0.06);
  --shadow-lg: 0 8px 40px rgba(0,0,0,0.10);
  --radius: 12px;
  --radius-sm: 8px;
  --radius-xs: 6px;
  --font: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
  --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ============ Reset & Base ============ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: var(--font); background: var(--bg-primary); color: var(--text-light); line-height: 1.6; -webkit-font-smoothing: antialiased; }
a { text-decoration: none; color: inherit; }
button { cursor: pointer; border: none; font-family: inherit; }
ul { list-style: none; }
img { max-width: 100%; display: block; }

/* ============ Navbar ============ */
.nav { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; background: rgba(28,28,28,0.92); backdrop-filter: blur(20px); border-bottom: 1px solid var(--border-dark); padding: env(safe-area-inset-top, 0px) 32px 0; height: calc(64px + env(safe-area-inset-top, 0px)); display: flex; align-items: center; justify-content: space-between; }
.nav-logo { font-size: 20px; font-weight: 700; letter-spacing: -0.5px; color: var(--text-light); display: flex; align-items: center; gap: 10px; }
.nav-logo .logo-mark { width: 36px; height: 36px; border-radius: var(--radius-xs); object-fit: contain; }
.nav-links { display: flex; gap: 32px; align-items: center; }
.nav-links a { font-size: 14px; color: var(--text-muted); transition: var(--transition); font-weight: 500; }
.nav-links a:hover, .nav-links a.active { color: var(--text-light); }
.nav-actions { display: flex; align-items: center; gap: 16px; }
.lang-toggle { display: flex; border-radius: 20px; overflow: hidden; border: 1px solid var(--border-dark); }
.lang-toggle button { padding: 5px 12px; font-size: 12px; font-weight: 600; background: transparent; color: var(--text-muted); transition: var(--transition); }
.lang-toggle button.active { background: var(--accent-moss); color: #fff; }
.nav-wa { padding: 8px 16px; border-radius: 20px; background: var(--whatsapp); color: #fff; font-size: 13px; font-weight: 600; display: flex; align-items: center; gap: 6px; transition: var(--transition); }
.nav-wa:hover { background: var(--whatsapp-dark); transform: translateY(-1px); }
.nav-wa-dot { width: 7px; height: 7px; border-radius: 50%; background: #fff; animation: pulse-dot 1.5s infinite; }
.hamburger { display: none; flex-direction: column; gap: 5px; background: none; padding: 4px; }
.hamburger span { width: 22px; height: 2px; background: var(--text-light); border-radius: 1px; transition: var(--transition); }
.hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
.hamburger.open span:nth-child(2) { opacity: 0; }
.hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

/* ============ About Tabs ============ */
.about-tab { padding: 10px 24px; font-size: 14px; font-weight: 600; background: transparent; color: var(--text-muted); border: 1px solid var(--border-dark); cursor: pointer; transition: var(--transition); }
.about-tab:first-child { border-radius: 20px 0 0 20px; }
.about-tab:last-child { border-radius: 0 20px 20px 0; }
.about-tab.active { background: var(--accent-moss); color: #fff; border-color: var(--accent-moss); }
.about-panel { animation: fadeSlideIn 0.4s ease; }
@keyframes fadeSlideIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
.certs-grid img { transition: transform 0.3s ease; }
.certs-grid img:hover { transform: scale(1.03); }

/* ============ Page Sections ============ */
.page-section { display: none; }
.page-section.active { display: block; }

/* ============ Hero ============ */
.hero { min-height: 100vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 120px 32px 80px; position: relative; overflow: hidden; background: var(--bg-primary); }
.hero-canvas { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; }
.hero-content { position: relative; z-index: 1; max-width: 780px; }
.hero-b2b-tags { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin-bottom: 22px; }
.hero-b2b-tag { padding: 5px 14px; border-radius: 20px; font-size: 12px; font-weight: 600; letter-spacing: 0.5px; background: rgba(45,125,210,0.15); border: 1px solid rgba(45,125,210,0.35); color: #90bef0; }
.hero-b2b-tag.gold { background: rgba(232,168,53,0.15); border-color: rgba(232,168,53,0.35); color: #f0c96a; }
.hero-badge { display: inline-flex; align-items: center; gap: 8px; padding: 8px 18px; border-radius: 20px; background: rgba(45,125,210,0.15); border: 1px solid rgba(45,125,210,0.3); font-size: 13px; color: var(--accent-moss-light); margin-bottom: 28px; }
.hero-badge .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--accent-moss); animation: pulse-dot 2s infinite; }
.hero h1 { font-size: clamp(36px, 6vw, 60px); font-weight: 700; line-height: 1.12; letter-spacing: -1.5px; margin-bottom: 20px; color: var(--text-light); }
.hero h1 em { font-style: normal; color: var(--accent-moss); }
.hero p { font-size: 17px; color: var(--text-muted); max-width: 600px; margin: 0 auto 36px; line-height: 1.7; }
.hero-btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
.btn { padding: 14px 28px; border-radius: 30px; font-size: 15px; font-weight: 600; transition: var(--transition); display: inline-flex; align-items: center; gap: 8px; }
.btn-light { background: var(--bg-surface); color: var(--text-dark); }
.btn-light:hover { background: #fff; transform: translateY(-2px); box-shadow: var(--shadow-lg); }
.btn-wa { background: var(--whatsapp); color: #fff; }
.btn-wa:hover { background: var(--whatsapp-dark); transform: translateY(-2px); box-shadow: 0 4px 20px rgba(37,211,102,0.3); }
.btn-dark { background: var(--bg-primary); color: var(--text-light); border: 1px solid var(--border-dark); }
.btn-dark:hover { background: var(--bg-secondary); transform: translateY(-2px); }
.btn-moss { background: var(--accent-moss); color: #fff; }
.btn-moss:hover { background: var(--accent-moss-dark); transform: translateY(-2px); }
.btn-copper { background: var(--accent-copper); color: #fff; }
.btn-copper:hover { background: #b87e5a; transform: translateY(-2px); }
.btn-sm { padding: 8px 18px; font-size: 13px; border-radius: 20px; }
.btn-gray-green { background: #4a5a4a; color: #c0c8bb; border: 1px solid #5a6a5a; }
.btn-gray-green:hover { background: #5a6e5a; color: #e0e4db; transform: translateY(-2px); }
.btn-back { display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; border-radius: 24px; background: var(--bg-secondary); color: var(--text-muted); font-size: 14px; font-weight: 500; cursor: pointer; transition: var(--transition); border: 1px solid var(--border-dark); margin-bottom: 32px; }
.btn-back:hover { color: var(--accent-moss); border-color: var(--accent-moss); }
.hero-scroll { margin-top: 60px; animation: bounce 2s infinite; color: var(--text-muted); font-size: 12px; }

/* ============ Content Sections ============ */
.section { padding: 100px 32px; }
.section-light { background: var(--bg-surface); color: var(--text-dark); }
.section-label { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: var(--accent-moss); margin-bottom: 12px; }
.section-title { font-size: clamp(28px, 4vw, 42px); font-weight: 700; letter-spacing: -1px; margin-bottom: 16px; line-height: 1.15; }
.section-subtitle { font-size: 16px; color: var(--text-muted); max-width: 580px; }
.section-light .section-subtitle { color: var(--text-muted-dark); }
.container { max-width: 1260px; margin: 0 auto; }

/* ============ Trust Bar ============ */
.trust-bar { border-bottom: 1px solid var(--border-dark); }
.trust-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 16px; }
.trust-item { text-align: center; padding: 24px 12px; }
.trust-num { font-size: 28px; font-weight: 700; color: var(--accent-moss); letter-spacing: -1px; }
.trust-label { font-size: 12px; color: var(--text-muted); margin-top: 4px; }

/* ============ Featured Categories (3 large) ============ */
.feat-cats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 20px; }
.feat-cat-card { position: relative; border-radius: var(--radius); overflow: hidden; cursor: pointer; transition: var(--transition); min-height: 180px; display: flex; align-items: center; justify-content: center; padding: 28px; background: var(--bg-secondary); border: 1px solid var(--border-dark); }
.feat-cat-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
.feat-cat-card:nth-child(1) { background: linear-gradient(135deg, #2a3028 0%, #1c1c1c 100%); border-color: rgba(125,148,116,0.3); }
.feat-cat-card:nth-child(1):hover { border-color: var(--accent-moss); }
.feat-cat-card:nth-child(2) { background: linear-gradient(135deg, #2a2826 0%, #1c1c1c 100%); border-color: rgba(200,149,108,0.3); }
.feat-cat-card:nth-child(2):hover { border-color: var(--accent-copper); }
.feat-cat-card:nth-child(3) { background: linear-gradient(135deg, #262a2c 0%, #1c1c1c 100%); border-color: rgba(140,160,170,0.3); }
.feat-cat-card:nth-child(3):hover { border-color: #9bb5c0; }
.feat-cat-card .feat-icon { position: absolute; top: 24px; right: 24px; font-size: 56px; opacity: 0.12; }
.feat-cat-content { position: relative; z-index: 1; }
.feat-cat-tag { display: inline-block; padding: 4px 10px; border-radius: 10px; font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 10px; }
.feat-cat-card:nth-child(1) .feat-cat-tag { background: rgba(125,148,116,0.2); color: var(--accent-moss); }
.feat-cat-card:nth-child(2) .feat-cat-tag { background: rgba(200,149,108,0.2); color: var(--accent-copper); }
.feat-cat-card:nth-child(3) .feat-cat-tag { background: rgba(140,160,170,0.2); color: #9bb5c0; }
.feat-cat-title { font-size: 22px; font-weight: 700; letter-spacing: -0.5px; color: var(--text-light); }
.feat-cat-sub { font-size: 13px; color: var(--text-muted); margin-top: 4px; }

/* ============ Sub Categories (smaller) ============ */
.sub-cats { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 24px; margin-top: 16px; }
.sub-cat-btn { padding: 5px 14px; border-radius: 16px; font-size: 11px; font-weight: 500; background: var(--bg-secondary); color: var(--text-muted); border: 1px solid transparent; transition: var(--transition); white-space: nowrap; }
.sub-cat-btn:hover { color: var(--text-light); border-color: var(--border-dark); }
.sub-cat-btn.active { background: var(--accent-moss); color: #fff; border-color: var(--accent-moss); }

/* ============ Products Grid ============ */
.products-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.product-card { background: var(--bg-secondary); border-radius: var(--radius); overflow: hidden; transition: var(--transition); cursor: pointer; border: 1px solid var(--border-dark); display: flex; flex-direction: column; }
.product-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: rgba(125,148,116,0.4); }
.product-card.disabled { opacity: 0.45; pointer-events: none; cursor: not-allowed; }
.product-img { height: 200px; background: #f5f5f5; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
.product-img .pi-placeholder { width: 100%; height: 100%; object-fit: cover; display: block; }
.product-img .pi-icon { font-size: 64px; opacity: 0.25; transition: var(--transition); }
.product-card:hover .product-img .pi-icon { transform: scale(1.08); opacity: 0.35; }
.product-badge { position: absolute; top: 12px; left: 12px; display: flex; gap: 6px; flex-direction: column; }
.badge { padding: 4px 10px; border-radius: 10px; font-size: 11px; font-weight: 700; letter-spacing: 0.5px; }
.badge-best { background: var(--accent-copper); color: #fff; }
.badge-new { background: var(--accent-moss); color: #fff; }
.badge-oos { background: #666; color: #aaa; }
.stock-dot { position: absolute; top: 12px; right: 12px; display: flex; align-items: center; gap: 5px; font-size: 11px; font-weight: 600; padding: 5px 10px; border-radius: 10px; background: rgba(0,0,0,0.6); color: #fff; }
.stock-dot::before { content: ''; width: 7px; height: 7px; border-radius: 50%; }
.stock-dot.in-stock::before { background: var(--success); }
.stock-dot.low-stock::before { background: var(--warning); }
.stock-dot.pre-order::before { background: var(--danger); }
.stock-dot.oos::before { background: #666; }
.product-info { padding: 18px; flex: 1; display: flex; flex-direction: column; }
.product-name { font-size: 17px; font-weight: 600; letter-spacing: -0.3px; margin-bottom: 4px; }
.product-spec { font-size: 12px; color: var(--text-muted); margin-bottom: 10px; line-height: 1.5; }
.product-bottom { margin-top: auto; display: flex; align-items: flex-end; justify-content: space-between; }
.product-price { font-size: 15px; font-weight: 700; }
.product-price span { font-size: 11px; color: var(--text-muted); font-weight: 400; }
.product-moq { font-size: 10px; color: var(--text-muted); }
.variant-dots { display: flex; gap: 5px; margin-bottom: 10px; }
.variant-dot { width: 8px; height: 8px; border-radius: 50%; }
.v-dot-std { background: #777; }
.v-dot-global { background: var(--accent-moss); }
.v-dot-anc { background: var(--accent-copper); }

/* ============ Product Detail Page ============ */
.product-page-header { padding: 80px 32px 0; background: var(--bg-primary); }
.product-page-header .container { max-width: 960px; }
.product-detail { display: grid; grid-template-columns: 1fr 1fr; max-width: 960px; margin: 0 auto 40px; background: var(--bg-secondary); border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border-dark); }
.pd-img-area { background: #f5f5f5; padding: 16px; display: flex; align-items: center; justify-content: center; position: relative; min-height: 160px; }
.pd-img-area img { max-width: 100%; max-height: 300px; object-fit: contain; display: block; }
.pd-img-area .pd-placeholder { width: 100%; height: auto; max-height: none; object-fit: cover; }
.pd-img-icon { font-size: 80px; opacity: 0.85; }
.pd-img-hint { position: absolute; bottom: 12px; left: 50%; transform: translateX(-50%); font-size: 11px; color: #888; background: rgba(0,0,0,0.55); padding: 5px 14px; border-radius: 10px; white-space: nowrap; z-index: 2; pointer-events: none; }
.pd-img-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
.pd-info { padding: 24px 28px; display: flex; flex-direction: column; }
.pd-cat { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; color: var(--accent-moss); margin-bottom: 4px; }
.pd-info h1 { font-size: 22px; font-weight: 700; letter-spacing: -0.6px; margin-bottom: 2px; color: var(--text-light); }
.pd-tagline { font-size: 13px; color: var(--text-muted); margin-bottom: 14px; }

/* Variant buttons (shared) */
.variant-selector { display: flex; gap: 6px; margin-bottom: 12px; flex-wrap: wrap; }
.variant-btn { padding: 7px 14px; border-radius: 18px; font-size: 12px; font-weight: 600; background: var(--bg-primary); color: var(--text-muted); border: 1px solid var(--border-dark); transition: var(--transition); }
.variant-btn:hover { color: var(--text-light); border-color: var(--text-muted); }
.variant-btn.active { background: var(--accent-moss); color: #fff; border-color: var(--accent-moss); }
.variant-btn.oos { opacity: 0.4; pointer-events: none; }

/* Specs table (shared) */
.specs-table { width: 100%; margin-bottom: 12px; border-collapse: collapse; }
.specs-table tr { border-bottom: 1px solid var(--border-dark); }
.specs-table td { padding: 4px 0; font-size: 12px; }
.specs-table td:first-child { color: var(--text-muted); width: 40%; font-size: 11px; }

/* Packaging options (shared) */
.pack-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-muted); margin-bottom: 6px; }
.packaging-options { display: flex; gap: 8px; margin-bottom: 12px; flex-wrap: wrap; }
.pack-option { padding: 8px 12px; border-radius: var(--radius-xs); border: 1px solid var(--border-dark); cursor: pointer; transition: var(--transition); flex: 1; text-align: center; font-size: 12px; min-width: 70px; background: var(--bg-primary); }
.pack-option:hover, .pack-option.selected { border-color: var(--accent-moss); background: rgba(125,148,116,0.1); }
.pack-option .pack-icon { font-size: 18px; margin-bottom: 2px; display: block; }

/* Price tiers (shared) */
.price-tiers { margin-bottom: 12px; }
.price-tier { display: flex; justify-content: space-between; padding: 8px 12px; border-radius: var(--radius-xs); margin-bottom: 4px; background: var(--bg-primary); font-size: 13px; border: 1.5px solid transparent; transition: all 0.3s ease; cursor: default; }
.price-tier .tier-label { color: var(--text-muted); font-size: 12px; }
.price-tier .tier-price { font-weight: 700; color: var(--text-light); }
.price-tier.selected { border-color: var(--accent-moss); background: rgba(125,148,116,0.12); }
.price-tier.selected .tier-label { color: var(--accent-moss); }
.price-tier.selected .tier-price { color: var(--accent-moss); }
.price-tier .tier-check { display: none; color: var(--accent-moss); font-size: 14px; margin-left: 6px; }
.price-tier.selected .tier-check { display: inline; }

/* Packaging preview */
.pack-preview { width: 100%; height: 80px; border-radius: var(--radius-xs); margin-bottom: 10px; display: flex; align-items: center; justify-content: center; background: var(--bg-primary); border: 1px solid var(--border-dark); overflow: hidden; transition: var(--transition); }
.pack-preview img { max-width: 100%; max-height: 100%; object-fit: contain; }
.pack-preview .pack-preview-icon { font-size: 36px; opacity: 0.4; }
.pack-preview .pack-preview-label { font-size: 11px; color: var(--text-muted); margin-top: 4px; text-align: center; }

/* Total price display */
.pd-total { display: flex; align-items: center; justify-content: space-between; padding: 10px 14px; border-radius: var(--radius-xs); background: rgba(125,148,116,0.08); border: 1px solid rgba(125,148,116,0.2); margin-bottom: 12px; }
.pd-total-label { font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
.pd-total-price { font-size: 20px; font-weight: 700; color: var(--accent-moss); letter-spacing: -0.5px; }
.pd-total-unit { font-size: 11px; color: var(--text-muted); font-weight: 400; }

/* Stock indicator (shared) */
.pd-stock { display: flex; align-items: center; gap: 6px; font-size: 13px; margin-bottom: 12px; }
.pd-stock .sdot { width: 8px; height: 8px; border-radius: 50%; }
.sdot.in { background: var(--success); }
.sdot.low { background: var(--warning); }
.sdot.out { background: var(--danger); }
.pd-actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: auto; }

/* ============ Why Us ============ */
.why-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.why-card { background: var(--bg-card); padding: 32px 24px; border-radius: var(--radius); border: 1px solid #e8e2d8; transition: var(--transition); }
.why-card:hover { border-color: var(--accent-moss); box-shadow: var(--shadow); }
.why-icon { width: 48px; height: 48px; border-radius: var(--radius-xs); background: var(--accent-moss-light); display: flex; align-items: center; justify-content: center; font-size: 20px; margin-bottom: 16px; }
.why-card h3 { font-size: 16px; font-weight: 600; margin-bottom: 8px; letter-spacing: -0.3px; }
.why-card p { font-size: 13px; color: var(--text-muted-dark); line-height: 1.6; }

/* ============ Global Reach ============ */
#global-reach { position: relative; background: url('images/global-reach-bg-dark.webp') center/cover no-repeat; background-color: var(--bg-primary); }
#global-reach::before { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(28,28,28,0.85) 0%, rgba(28,28,28,0.65) 50%, rgba(28,28,28,0.88) 100%); z-index: 0; }
#global-reach .container { position: relative; z-index: 1; }
.reach-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.reach-card { background: var(--bg-dark-card); border-radius: var(--radius); padding: 32px 24px; border: 1px solid var(--border-dark); transition: var(--transition); text-align: center; }
.reach-card:hover { border-color: var(--accent-moss); }
.reach-flag { font-size: 40px; margin-bottom: 14px; }
.reach-card h3 { font-size: 18px; font-weight: 600; margin-bottom: 6px; }
.reach-card .address { font-size: 12px; color: var(--text-muted); margin-bottom: 14px; line-height: 1.5; }
.reach-map { width: 100%; height: auto; border-radius: 6px; margin-bottom: 14px; display: block; border: 1px solid var(--border-dark); }
.reach-card .eta { font-size: 13px; color: var(--accent-moss); font-weight: 600; }

/* ============ Reviews ============ */
.reviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.review-card { background: var(--bg-card); padding: 28px; border-radius: var(--radius); border: 1px solid #e8e2d8; }
.review-stars { color: var(--accent-copper); font-size: 14px; margin-bottom: 14px; letter-spacing: 2px; }
.review-text { font-size: 14px; line-height: 1.7; color: var(--text-dark); margin-bottom: 16px; font-style: italic; }
.review-author { display: flex; align-items: center; gap: 10px; }
.review-avatar { width: 40px; height: 40px; border-radius: 50%; background: var(--accent-moss-light); display: flex; align-items: center; justify-content: center; font-weight: 700; color: var(--accent-moss-dark); font-size: 16px; }
.review-author strong { font-size: 14px; display: block; }
.review-author span { font-size: 12px; color: var(--text-muted-dark); }

/* ============ Process ============ */
.process-steps { display: grid; grid-template-columns: repeat(6, 1fr); gap: 8px; }
.process-step { text-align: center; position: relative; }
.process-step::after { content: ''; position: absolute; top: 24px; left: 60%; width: 80%; height: 1px; background: var(--border); }
.process-step:last-child::after { display: none; }
.section-light .process-step::after { background: #d8d4cb; }
.process-num { width: 48px; height: 48px; border-radius: 50%; background: var(--bg-primary); color: var(--text-light); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 18px; margin: 0 auto 12px; }
.process-step h4 { font-size: 13px; font-weight: 600; margin-bottom: 4px; }
.section-light .process-step p { font-size: 11px; color: var(--text-muted-dark); }

/* ============ Contact ============ */
.contact-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 48px; align-items: start; }
.contact-info h3 { font-size: 22px; font-weight: 700; margin-bottom: 12px; color: var(--text-dark); }
.section-light .contact-info p { color: var(--text-muted-dark); margin-bottom: 24px; }
.contact-item { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; font-size: 14px; color: var(--text-dark); }
.contact-item .ci-icon { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px; background: #e8e2d8; flex-shrink: 0; }
.contact-form { background: var(--bg-dark-card); padding: 32px; border-radius: var(--radius); border: 1px solid var(--border-dark); }
.contact-form .form-title { color: var(--text-light); font-size: 18px; font-weight: 600; margin-bottom: 20px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
.form-row.single { grid-template-columns: 1fr; }
.form-group label { display: block; font-size: 12px; font-weight: 600; margin-bottom: 5px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
.form-group input, .form-group select, .form-group textarea { width: 100%; padding: 12px 14px; border-radius: var(--radius-xs); border: 1px solid var(--border-dark); background: var(--bg-primary); color: var(--text-light); font-size: 14px; font-family: inherit; transition: var(--transition); }
.form-group input:focus, .form-group select:focus, .form-group textarea:focus { outline: none; border-color: var(--accent-moss); }
.form-group textarea { resize: vertical; min-height: 90px; }

/* ============ Footer ============ */
.footer { background: #151515; padding: 60px 32px 28px; border-top: 1px solid var(--border-dark); }
.footer-grid { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 40px; }
.footer h4 { font-size: 12px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-muted); margin-bottom: 16px; }
.footer a { font-size: 13px; color: #777; display: block; margin-bottom: 8px; transition: var(--transition); }
.footer a:hover { color: var(--accent-moss); }
.footer-brand p { font-size: 13px; color: #777; margin-top: 10px; line-height: 1.6; }
.footer-bottom { margin-top: 40px; padding-top: 16px; border-top: 1px solid var(--border-dark); text-align: center; font-size: 12px; color: #555; }

/* ============ Floating Elements ============ */
.floating-wa, .floating-cart { position: fixed; z-index: 999; border-radius: 50%; width: 52px; height: 52px; display: flex; align-items: center; justify-content: center; font-size: 24px; box-shadow: 0 4px 20px rgba(0,0,0,0.4); transition: var(--transition); }
.floating-wa { bottom: 28px; right: 28px; background: var(--whatsapp); color: #fff; animation: wa-pulse 2.5s infinite; }
.floating-cart { bottom: 92px; right: 28px; background: var(--bg-secondary); color: var(--text-light); border: 1px solid var(--border-dark); }
.floating-cart .cart-count { position: absolute; top: -4px; right: -4px; width: 20px; height: 20px; border-radius: 50%; background: var(--accent-copper); color: #fff; font-size: 11px; font-weight: 700; display: flex; align-items: center; justify-content: center; }
.floating-wa:hover, .floating-cart:hover { transform: scale(1.08); }

/* ============ Cart Panel ============ */
.cart-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 2000; opacity: 0; pointer-events: none; transition: opacity 0.3s; }
.cart-overlay.open { opacity: 1; pointer-events: auto; }
.cart-panel { position: fixed; top: 0; right: 0; width: 400px; max-width: 100vw; height: 100vh; background: var(--bg-primary); z-index: 2001; display: flex; flex-direction: column; transform: translateX(100%); transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1); border-left: 1px solid var(--border-dark); }
.cart-panel.open { transform: translateX(0); }
.cart-header { padding: 16px 20px; border-bottom: 1px solid var(--border-dark); display: flex; justify-content: space-between; align-items: center; }
.cart-header h3 { font-size: 16px; font-weight: 600; }
.cart-close { width: 32px; height: 32px; border-radius: 50%; background: var(--bg-secondary); color: var(--text-muted); font-size: 16px; display: flex; align-items: center; justify-content: center; }
.cart-items { flex: 1; overflow-y: auto; padding: 12px 16px; scrollbar-width: none; -ms-overflow-style: none; }
.cart-items::-webkit-scrollbar { display: none; }
.cart-item { display: flex; gap: 14px; padding: 14px 0; border-bottom: 1px solid var(--border-dark); align-items: center; }
.cart-item-img { width: 56px; height: 56px; border-radius: var(--radius-xs); background: #f5f5f5; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 28px; overflow: hidden; }
.cart-item-img img { width: 100%; height: 100%; object-fit: contain; padding: 4px; }
.cart-item-info { flex: 1; }
.cart-item-name { font-size: 14px; font-weight: 600; }
.cart-item-variant { font-size: 11px; color: var(--text-muted); margin-bottom: 4px; }
.cart-item-price { font-size: 13px; font-weight: 600; }
.cart-item-qty { display: flex; align-items: center; gap: 8px; margin-top: 8px; }
.cart-item-qty button { width: 26px; height: 26px; border-radius: 50%; background: var(--bg-secondary); color: var(--text-light); font-size: 14px; display: flex; align-items: center; justify-content: center; transition: var(--transition); }
.cart-item-qty button:hover { background: var(--accent-moss); }
.cart-item-qty span { font-size: 14px; font-weight: 600; min-width: 24px; text-align: center; }
.cart-item-remove { color: var(--danger); font-size: 18px; cursor: pointer; background: none; padding: 0 4px; flex-shrink: 0; }
.cart-empty { text-align: center; padding: 60px 20px; color: var(--text-muted); font-size: 14px; }
.cart-footer { padding: 20px 24px; border-top: 1px solid var(--border-dark); }
.cart-total { display: flex; justify-content: space-between; margin-bottom: 14px; font-size: 14px; }
.cart-total strong { font-size: 18px; }
.cart-wa-btn { width: 100%; padding: 14px; border-radius: 28px; background: var(--whatsapp); color: #fff; font-size: 15px; font-weight: 600; display: flex; align-items: center; justify-content: center; gap: 8px; transition: var(--transition); }
.cart-wa-btn:hover { background: var(--whatsapp-dark); }
.cart-continue { width: 100%; padding: 10px; margin-top: 8px; background: transparent; color: var(--text-muted); font-size: 13px; }

/* Address Panel — floats to the left of the cart */
.cart-addr-panel { position: fixed; top: 80px; right: 400px; width: 280px; background: #1e221e; border: 1px solid rgba(125,148,116,0.35); border-right: none; border-radius: 14px 0 0 14px; z-index: 2001; transform: translateX(16px); opacity: 0; pointer-events: none; transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: -4px 8px 40px rgba(0,0,0,0.5); }
.cart-addr-panel.open { transform: translateX(0); opacity: 1; pointer-events: auto; }
/* Connector tab — gone, panel sticks directly */
.cart-addr-panel h4 { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; color: var(--accent-moss); margin: 0; padding: 14px 16px 10px; border-bottom: 1px solid rgba(125,148,116,0.15); }
.cart-addr-inner { padding: 12px 16px 14px; }
.cart-addr-inner .addr-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 8px; }
.cart-addr-inner .addr-row.single { grid-template-columns: 1fr; }
.cart-addr-input { width: 100%; padding: 8px 10px; border-radius: var(--radius-xs); border: 1px solid var(--border-dark); background: var(--bg-secondary); color: var(--text-light); font-size: 12px; font-family: inherit; transition: var(--transition); }
.cart-addr-input:focus { outline: none; border-color: var(--accent-moss); }
.cart-addr-input::placeholder { color: #555; }
.cart-addr-select { width: 100%; padding: 8px 10px; border-radius: var(--radius-xs); border: 1px solid var(--border-dark); background: var(--bg-secondary); color: var(--text-light); font-size: 12px; font-family: inherit; cursor: pointer; transition: var(--transition); -webkit-appearance: none; appearance: none; }
.cart-addr-select:focus { outline: none; border-color: var(--accent-moss); }
.cart-addr-select option { background: var(--bg-secondary); color: var(--text-light); }
.cart-addr-select option.remote { color: #777; }
.cart-addr-warn { color: var(--warning); font-size: 10px; margin-top: 4px; text-align: center; display: none; }
.addr-send-btn { display: none; width: 100%; padding: 14px; border-radius: 28px; background: var(--whatsapp); color: #fff; font-size: 15px; font-weight: 600; align-items: center; justify-content: center; gap: 8px; transition: var(--transition); margin-top: 12px; cursor: pointer; border: none; }
.addr-send-btn:hover { background: var(--whatsapp-dark); }

/* ============ Animations ============ */
@keyframes pulse-dot { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
@keyframes wa-pulse { 0%, 100% { box-shadow: 0 4px 20px rgba(37,211,102,0.3); } 50% { box-shadow: 0 4px 30px rgba(37,211,102,0.6); } }
@keyframes bounce { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(8px); } }
@keyframes fadeIn { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
.animate-in { animation: fadeIn 0.45s ease-out forwards; }

/* ============ Responsive ============ */
@media (max-width: 1024px) {
  .products-grid, .feat-cats { grid-template-columns: repeat(2, 1fr); }
  .trust-grid { grid-template-columns: repeat(3, 1fr); }
  .why-grid { grid-template-columns: repeat(2, 1fr); }
  .reviews-grid { grid-template-columns: repeat(2, 1fr); }
  .process-steps { grid-template-columns: repeat(3, 1fr); }
  .process-step::after { display: none; }
  .footer-grid { grid-template-columns: repeat(2, 1fr); }
  .product-detail { grid-template-columns: 1fr; }
  .pd-img-area { min-height: 200px; border-radius: var(--radius) var(--radius) 0 0; }
}
@media (max-width: 768px) {
  .nav { padding-left: 16px; padding-right: calc(16px + env(safe-area-inset-right, 0px)); }
  .nav-actions { gap: 10px; }
  .nav-wa { padding: 8px 12px; }
  .nav-links { display: none; position: fixed; top: calc(64px + env(safe-area-inset-top, 0px)); left: 0; right: 0; background: rgba(28,28,28,0.98); backdrop-filter: blur(20px); flex-direction: column; padding: 16px 32px; gap: 0; border-bottom: 1px solid var(--border-dark); }
  .nav-links.open { display: flex; }
  .nav-links a { padding: 14px 0; border-bottom: 1px solid var(--border-dark); font-size: 16px; }
  .nav-links .lang-toggle { margin-top: 16px; justify-content: center; border: 1px solid var(--border-dark); border-radius: 20px; overflow: hidden; display: flex; }
  .nav-links .lang-toggle button { padding: 10px 24px; font-size: 14px; }
  .nav-wa span { display: none; }
  .hamburger { display: flex; }
  .products-grid { grid-template-columns: 1fr; }
  .feat-cats { grid-template-columns: repeat(3, 1fr); gap: 8px; }
  .feat-cat-card { padding: 12px 8px; min-height: 60px; border-radius: var(--radius-sm); }
  .feat-cat-title { font-size: 13px; }
  .sub-cats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; }
  .sub-cats button { text-align: center; width: 100%; padding: 6px 10px; font-size: 11px; border-radius: 16px; }
  .trust-grid { grid-template-columns: repeat(2, 1fr); }
  .why-grid { grid-template-columns: 1fr; }
  .reach-grid { grid-template-columns: 1fr; }
  .reviews-grid { grid-template-columns: 1fr; }
  .process-steps { grid-template-columns: repeat(2, 1fr); }
  .contact-grid { grid-template-columns: 1fr; }
  .footer-grid { grid-template-columns: 1fr; }
  .hero h1 { font-size: 30px; }
  .section { padding: 60px 16px; }
  .cart-panel { width: 100vw; }
  .cart-addr-panel { position: fixed; top: auto; bottom: 0; right: 0; left: 0; width: 100vw; max-height: 70vh; overflow-y: auto; border-radius: 14px 14px 0 0; transform: translateY(100%); }
  .cart-addr-panel.open { transform: translateY(0); }
  .cart-addr-panel::after { display: none; }
  .addr-send-btn { display: flex; }
  .cart-panel.open ~ .cart-addr-panel { /* sibling selector for mobile */ }
  .form-row { grid-template-columns: 1fr; }
  .product-page-header { padding: 72px 12px 0; }
  .product-detail { margin-bottom: 24px; }
  .pd-img-area { min-height: 180px; padding: 16px 12px; }
  .pd-info { padding: 20px; }
  .about-stats { grid-template-columns: repeat(2, 1fr) !important; }
  .about-philo { grid-template-columns: 1fr !important; }
  .about-tabs { gap: 4px !important; }
  .about-tab { padding: 8px 14px !important; font-size: 12px !important; }
  .about-tab:first-child { border-radius: 18px 0 0 18px !important; }
  .about-tab:last-child { border-radius: 0 18px 18px 0 !important; }
  .certs-grid { grid-template-columns: repeat(2, 1fr) !important; gap: 8px !important; }
}

/* ============ Verify Grid ============ */
.verify-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
@media (max-width: 1024px) {
  .verify-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 768px) {
  .verify-grid { grid-template-columns: 1fr; }
}



/* ============ Visual Theme Refresh 2026 ============ */
:root {
  --bg-primary: #0b1118;
  --bg-secondary: #101923;
  --bg-surface: #f6f0e6;
  --bg-card: #fffdf8;
  --bg-dark-card: #13202c;
  --accent-moss: #2fd08b;
  --accent-moss-dark: #159b69;
  --accent-moss-light: #dff8ec;
  --accent-copper: #ffb84d;
  --accent-copper-light: #fff2d6;
  --text-dark: #18202a;
  --text-light: #f5f8f6;
  --text-muted: #91a2ad;
  --text-muted-dark: #66727c;
  --border: rgba(34, 49, 62, 0.12);
  --border-dark: rgba(195, 229, 221, 0.13);
  --shadow: 0 14px 42px rgba(8, 15, 24, 0.12);
  --shadow-lg: 0 24px 70px rgba(5, 12, 20, 0.24);
}

body {
  background:
    radial-gradient(circle at 12% 8%, rgba(47,208,139,0.24), transparent 28rem),
    radial-gradient(circle at 88% 18%, rgba(255,184,77,0.18), transparent 25rem),
    linear-gradient(135deg, #071018 0%, #101923 45%, #142235 100%);
  color: var(--text-light);
  overflow-x: hidden;
}

.nav {
  background: rgba(8, 14, 21, 0.78);
  border-bottom: 1px solid rgba(255,255,255,0.08);
  box-shadow: 0 10px 36px rgba(0,0,0,0.18);
}

.hero {
  min-height: 100vh;
  justify-content: center;
  text-align: left;
  padding: 124px 32px 72px;
  isolation: isolate;
  background:
    linear-gradient(125deg, rgba(7, 13, 20, 0.96), rgba(12, 28, 38, 0.86) 45%, rgba(17, 32, 47, 0.94)),
    radial-gradient(circle at 70% 45%, rgba(47,208,139,0.3), transparent 34rem);
}

.hero::before,
.hero::after {
  content: '';
  position: absolute;
  pointer-events: none;
  z-index: 0;
}

.hero::before {
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.055) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.055) 1px, transparent 1px);
  background-size: 72px 72px;
  mask-image: linear-gradient(to bottom, rgba(0,0,0,0.72), transparent 82%);
  opacity: 0.46;
}

.hero::after {
  width: 52vw;
  height: 52vw;
  min-width: 520px;
  min-height: 520px;
  right: -18vw;
  top: 8vh;
  border-radius: 50%;
  background: conic-gradient(from 90deg, rgba(47,208,139,0.38), rgba(255,184,77,0.34), rgba(45,125,210,0.22), rgba(47,208,139,0.38));
  filter: blur(54px);
  opacity: 0.55;
  animation: heroGradient 12s linear infinite;
}

.hero-canvas { opacity: 0.52; mix-blend-mode: screen; }
.hero-shell { position: relative; z-index: 2; width: min(1260px, 100%); display: grid; grid-template-columns: minmax(0, 1fr) minmax(420px, 0.88fr); gap: 56px; align-items: center; }
.hero-content { max-width: 680px; }
.hero-copy { animation: heroFadeUp 0.8s ease-out both; }
.hero-badge { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.14); color: #ddfff2; box-shadow: inset 0 1px 0 rgba(255,255,255,0.12); }
.hero-badge .dot { background: var(--accent-moss); box-shadow: 0 0 18px rgba(47,208,139,0.8); }
.hero h1 { font-size: clamp(48px, 7vw, 86px); line-height: 0.95; letter-spacing: -3.2px; margin-bottom: 24px; max-width: 760px; }
.hero h1 em { color: transparent; background: linear-gradient(90deg, var(--accent-moss), #b8ffdb 45%, var(--accent-copper)); -webkit-background-clip: text; background-clip: text; text-shadow: none; }
.hero p { margin: 0 0 28px; max-width: 610px; color: #bfd0d5; font-size: clamp(16px, 1.7vw, 19px); }
.hero-b2b-tags { justify-content: flex-start; margin: 0 0 32px; }
.hero-b2b-tag { background: rgba(255,255,255,0.07); border-color: rgba(255,255,255,0.12); color: #cfe9ec; backdrop-filter: blur(12px); }
.hero-b2b-tag.gold { background: rgba(255,184,77,0.13); border-color: rgba(255,184,77,0.34); color: #ffd78d; }
.hero-btns { justify-content: flex-start; }
.btn { box-shadow: 0 10px 28px rgba(0,0,0,0.15); }
.btn-light { background: linear-gradient(135deg, #ffffff, #e9f6ef); color: #0f1d25; }
.btn-moss { background: linear-gradient(135deg, var(--accent-moss), #1aa6a8); }
.btn-wa { background: linear-gradient(135deg, #25D366, #12b886); }
.hero-proof { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; margin-top: 34px; max-width: 560px; }
.hero-proof div { padding: 14px 16px; border: 1px solid rgba(255,255,255,0.1); border-radius: 18px; background: rgba(255,255,255,0.06); backdrop-filter: blur(14px); }
.hero-proof strong { display: block; font-size: 24px; line-height: 1; color: #fff; }
.hero-proof span { display: block; margin-top: 6px; font-size: 12px; color: #9fb4bd; }
.hero-visual { position: relative; min-height: 560px; display: flex; align-items: center; justify-content: center; animation: heroFadeUp 0.9s 0.08s ease-out both; }
.hero-device-card { position: relative; width: min(520px, 92vw); aspect-ratio: 1; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: radial-gradient(circle at 50% 48%, rgba(255,255,255,0.14), rgba(255,255,255,0.04) 42%, transparent 70%); }
.hero-product { position: relative; z-index: 3; width: min(440px, 78vw); filter: drop-shadow(0 34px 46px rgba(0,0,0,0.38)); animation: heroFloat 5.5s ease-in-out infinite; }
.hero-glow { position: absolute; z-index: 1; width: 70%; height: 28%; bottom: 12%; border-radius: 50%; background: radial-gradient(ellipse, rgba(47,208,139,0.45), transparent 68%); filter: blur(22px); animation: glowPulse 4.5s ease-in-out infinite; }
.hero-ring { position: absolute; inset: 7%; border-radius: 50%; border: 1px solid rgba(255,255,255,0.16); }
.hero-ring-one { border-left-color: rgba(47,208,139,0.7); border-top-color: rgba(255,184,77,0.5); animation: ringSpin 18s linear infinite; }
